---
import ElsewhereCard from "../components/cards/ElsewhereCard.astro";
import GlassCard from "../components/common/GlassCard.astro";
import MobileHeader from "../components/MobileHeader.astro";
import Sidebar from "../components/Sidebar.astro";
import { siteData } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const { socials, bio, secondaryBio } = siteData;
---

<BaseLayout title="Connect | TajemnikTV">
	<div class="flex min-h-screen w-full relative">
		<Sidebar />

		<main
			class="flex-1 lg:ml-36 px-6 py-8 lg:pr-12 w-full max-w-250 mx-auto flex flex-col"
		>
			<MobileHeader />

			<header class="mb-12">
				<h1 class="text-4xl md:text-5xl font-bold mb-4 gradient-text">
					Connect
				</h1>
				<p class="text-lg text-gray-300 max-w-2xl">
					Places where TajemnikTV exists publicly. No fake contact form, no
					recruiter bait, no mystery inbox.
				</p>
			</header>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<!-- About / Contact Info -->
				<GlassCard class="p-8 flex flex-col justify-between">
					<div>
						<h2 class="text-2xl font-bold text-white mb-4">Public signals</h2>
						<p class="text-gray-300 mb-6 leading-relaxed">
							The site is mainly an identity hub and project dashboard. If you
							need the real trail, GitHub and the linked profiles are the safest
							public entry points.
						</p>
						<p class="text-gray-300 mb-8 leading-relaxed">
							{bio}
						</p>
						<p class="text-gray-400 leading-relaxed">{secondaryBio}</p>
					</div>

					<div class="mt-8 rounded-2xl border border-white/10 bg-white/4 p-4">
						<p
							class="text-xs font-bold uppercase tracking-[0.18em] text-primary mb-2"
						>
							Verified links only
						</p>
						<p class="text-sm text-gray-400 leading-relaxed">
							Steam Workshop, Discord, and other profiles are intentionally not
							listed until there is a confirmed public URL to point at.
						</p>
					</div>
				</GlassCard>

				<!-- Socials -->
				<div class="flex flex-col gap-6">
					<ElsewhereCard links={socials} />

					<GlassCard
						class="p-6 bg-linear-to-br from-indigo-900/40 to-purple-900/40 border-indigo-500/20"
					>
						<h3
							class="text-xl font-bold text-white mb-2 flex items-center gap-2"
						>
							<span class="material-symbols-outlined">handshake</span>
							Current posture
						</h3>
						<p class="text-sm text-gray-300 mb-4">
							Building, studying, modding, tuning, listening, thinking too much,
							and occasionally shipping the useful parts.
						</p>
						<div
							class="flex items-center gap-2 text-xs font-bold text-indigo-300 uppercase tracking-widest"
						>
							Mode: <span class="text-cyan-200">Overthinking with purpose</span>
						</div>
					</GlassCard>
				</div>
			</div>
		</main>
	</div>
</BaseLayout>
