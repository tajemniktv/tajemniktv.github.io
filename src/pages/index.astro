---
import ElsewhereCard from "../components/cards/ElsewhereCard.astro";
import HeroCard from "../components/cards/HeroCard.astro";
import LabNotesCard from "../components/cards/LabNotesCard.astro";
import PillarCard from "../components/cards/PillarCard.astro";
import ProjectCard from "../components/cards/ProjectCard.astro";
import ReadingCard from "../components/cards/ReadingCard.astro";
import Footer from "../components/Footer.astro";
import MobileHeader from "../components/MobileHeader.astro";
import Sidebar from "../components/Sidebar.astro";
import { dashboardData } from "../data/dashboard";
import BaseLayout from "../layouts/BaseLayout.astro";

const { hero, pillars, projects, inputQueue, lab, elsewhere } = dashboardData;
---

<BaseLayout title="TajemnikTV.exe | Grzegorz Kaczmarski">
	<div class="flex min-h-screen w-full relative">
		<Sidebar />

		<main class="flex-1 lg:ml-36 px-6 py-8 lg:pr-12 w-full max-w-350 mx-auto">
			<MobileHeader />

			<div
				class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 auto-rows-min"
			>
				<div id="home" class="contents">
					<HeroCard {...hero} />
				</div>

				<div id="lab" class="contents">
					<LabNotesCard {...lab} />
				</div>

				<div id="projects" class="col-span-1 md:col-span-2 lg:col-span-4">
					<div
						class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-4"
					>
						<div>
							<p
								class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-2"
							>
								Project Cockpit
							</p>
							<h2 class="text-3xl font-bold text-white">Active chaos lanes</h2>
						</div>
						<p class="text-sm text-gray-400 max-w-xl">
							Things I am building, overthinking, or orbiting. Some are public,
							some are still mostly ideas with suspiciously detailed notes.
						</p>
					</div>
				</div>

				{projects.map((project) => <ProjectCard {...project} />)}

				<div id="highlights" class="col-span-1 md:col-span-2 lg:col-span-4">
					<div
						class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-4 mt-2"
					>
						<div>
							<p
								class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-2"
							>
								Identity Pillars
							</p>
							<h2 class="text-3xl font-bold text-white">
								The recurring obsessions
							</h2>
						</div>
						<a
							href="/highlights"
							class="inline-flex items-center gap-2 text-sm font-bold text-cyan-100 hover:text-white transition-colors"
						>
							More context
							<span class="material-symbols-outlined text-lg"
								>arrow_forward</span
							>
						</a>
					</div>
				</div>

				{pillars.map((pillar) => <PillarCard {...pillar} />)}

				<ReadingCard {...inputQueue} />

				<div id="links" class="contents">
					<ElsewhereCard links={elsewhere} />
				</div>

				<div id="contact" class="contents">
					<Footer />
				</div>
			</div>
		</main>
	</div>
</BaseLayout>
