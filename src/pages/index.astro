---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import MobileHeader from "../components/MobileHeader.astro";
import HeroCard from "../components/cards/HeroCard.astro";
import PillarCard from "../components/cards/PillarCard.astro";
import ReadingCard from "../components/cards/ReadingCard.astro";
import LatestEssayCard from "../components/cards/LatestEssayCard.astro";
import ElsewhereCard from "../components/cards/ElsewhereCard.astro";
import Footer from "../components/Footer.astro";
import { dashboardData } from "../data/dashboard";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPost = posts[0];

// Merge dynamic data with dashboard defaults
const { hero, pillars, reading, elsewhere } = dashboardData;
const latestEssayData = latestPost
  ? {
      title: latestPost.data.title,
      excerpt: latestPost.data.description,
      readTime:
        Math.ceil(latestPost.body.split(/\s+/).length / 200) + " min read",
      coverUrl:
        latestPost.data.heroImage || "/images/essay-cover-placeholder.png",
      slug: latestPost.slug,
    }
  : dashboardData.latestEssay;
---

<BaseLayout title="TajemnikTV - Personal Home Dashboard">
  <div class="flex min-h-screen w-full relative">
    <Sidebar />

    <main
      class="flex-1 lg:ml-36 px-6 py-8 lg:pr-12 w-full max-w-[1400px] mx-auto"
    >
      <MobileHeader />

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 auto-rows-min"
      >
        <!-- Hero Card (Home) -->
        <div id="home" class="contents">
          <HeroCard {...hero} />
        </div>

        <!-- Pillar Cards -->
        {pillars.map((pillar) => <PillarCard {...pillar} />)}

        <!-- Reading Card (Highlights) -->
        <div id="highlights" class="contents">
          <ReadingCard {...reading} />
        </div>

        <!-- Latest Essay (Writing) -->
        <div id="writing" class="contents">
          <a href={latestPost ? `/writing/${latestPost.slug}` : "/writing"}>
            <LatestEssayCard {...latestEssayData} />
          </a>
        </div>

        <!-- Elsewhere / Socials (Links) -->
        <div id="links" class="contents">
          <ElsewhereCard links={elsewhere} />
        </div>

        <!-- Footer (Contact) -->
        <div id="contact" class="contents">
          <Footer />
        </div>
      </div>
    </main>
  </div>
</BaseLayout>
