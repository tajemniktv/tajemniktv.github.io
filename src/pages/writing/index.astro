---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Lab Notes | TajemnikTV">
	<Fragment slot="head">
		<meta http-equiv="refresh" content="0; url=/lab" />
	</Fragment>
	<main
		class="min-h-screen bg-background-dark text-white grid place-items-center px-6"
	>
		<div class="max-w-md text-center">
			<h1 class="text-3xl font-bold mb-3">Old route moved to Lab Notes.</h1>
			<p class="text-gray-300 mb-6">
				The formal blog costume has been retired. The useful bits live in the
				lab now.
			</p>
			<a
				href="/lab"
				class="inline-flex items-center gap-2 rounded-full bg-primary px-5 py-3 text-sm font-bold text-white"
			>
				Open Lab Notes
				<span class="material-symbols-outlined text-lg" aria-hidden="true">arrow_forward</span>
			</a>
		</div>
	</main>
</BaseLayout>
