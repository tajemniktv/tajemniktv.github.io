---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
	const posts = await getCollection("lab");
	return posts
		.filter((post) => !post.data.draft)
		.map((post) => ({
			params: { slug: post.id.replace(/\.md$/, "") },
		}));
}

const { slug } = Astro.params;
---

<BaseLayout title="Lab Notes | TajemnikTV">
	<Fragment slot="head">
		<meta http-equiv="refresh" content={`0; url=/lab/${slug}`} />
	</Fragment>
	<main
		class="min-h-screen bg-background-dark text-white grid place-items-center px-6"
	>
		<div class="max-w-md text-center">
			<h1 class="text-3xl font-bold mb-3">This note moved.</h1>
			<p class="text-gray-300 mb-6">
				The old writing route now points to the Lab Notes version.
			</p>
			<a
				href={`/lab/${slug}`}
				class="inline-flex items-center gap-2 rounded-full bg-primary px-5 py-3 text-sm font-bold text-white"
			>
				Open Lab Note
				<span class="material-symbols-outlined text-lg">arrow_forward</span>
			</a>
		</div>
	</main>
</BaseLayout>
