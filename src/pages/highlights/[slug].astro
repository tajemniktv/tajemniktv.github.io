---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Sidebar from "../../components/Sidebar.astro";
import MobileHeader from "../../components/MobileHeader.astro";
import GlassCard from "../../components/common/GlassCard.astro";
import { highlightsData } from "../../data/highlights";

export function getStaticPaths() {
  return highlightsData.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
---

<BaseLayout title={`${item.title} - Highlights | TajemnikTV`}>
  <div class="flex min-h-screen w-full relative">
    <Sidebar />

    <main
      class="flex-1 lg:ml-36 px-6 py-8 lg:pr-12 w-full max-w-[1000px] mx-auto flex flex-col"
    >
      <MobileHeader />

      <a
        href="/highlights"
        class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors mb-8 group"
      >
        <span
          class="material-symbols-outlined text-lg group-hover:-translate-x-1 transition-transform"
          >arrow_back</span
        >
        Highlights
      </a>

      <!-- Hero -->
      <header class="mb-10">
        <GlassCard class="p-8 relative overflow-hidden">
          <div
            class="absolute top-0 right-0 w-64 h-64 bg-primary/10 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/2 pointer-events-none"
          >
          </div>

          <div class="relative z-10">
            <div class="flex items-center gap-4 mb-6">
              <div
                class="w-16 h-16 rounded-2xl bg-surface-light border border-white/5 flex items-center justify-center text-primary shadow-xl"
              >
                <span class="material-symbols-outlined text-4xl"
                  >{item.icon}</span
                >
              </div>
              <div>
                {
                  item.hero.statusChip && (
                    <div class="flex items-center gap-2 text-xs font-bold text-accent-purple uppercase tracking-wider mb-2">
                      <span class="w-2 h-2 rounded-full bg-accent-purple animate-pulse" />
                      {item.hero.statusChip}
                    </div>
                  )
                }
                <h1 class="text-4xl font-bold text-white">{item.title}</h1>
              </div>
            </div>

            <p
              class="text-xl text-gray-200 leading-relaxed max-w-2xl font-medium"
            >
              {item.hero.subtitle}
            </p>
          </div>
        </GlassCard>
      </header>

      <!-- Sections -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          item.sections.map((section) => (
            <GlassCard class="p-6 h-full flex flex-col">
              <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                <span class="w-1 h-6 bg-primary rounded-full" />
                {section.title}
              </h2>

              <ul class="flex flex-col gap-3">
                {section.items.map((subItem) => (
                  <li>
                    {subItem.href ? (
                      <a
                        href={subItem.href}
                        class="group block p-3 rounded-xl bg-surface-light hover:bg-white/10 transition-colors border border-white/5 hover:border-white/10"
                      >
                        <div class="flex items-start justify-between">
                          <div class="flex items-center gap-2">
                            {subItem.icon && (
                              <span class="material-symbols-outlined text-gray-400 text-sm group-hover:text-primary transition-colors">
                                {subItem.icon}
                              </span>
                            )}
                            <span class="font-bold text-gray-200 group-hover:text-white transition-colors">
                              {subItem.label}
                            </span>
                          </div>
                          <span class="material-symbols-outlined text-gray-500 text-sm group-hover:translate-x-1 transition-transform">
                            arrow_forward
                          </span>
                        </div>
                        {subItem.description && (
                          <p class="text-xs text-gray-400 mt-1 pl-0.5">
                            {subItem.description}
                          </p>
                        )}
                      </a>
                    ) : (
                      <div class="p-3 rounded-xl bg-white/5 border border-transparent">
                        <div class="flex items-center gap-2 mb-1">
                          {subItem.icon && (
                            <span class="material-symbols-outlined text-gray-500 text-sm">
                              {subItem.icon}
                            </span>
                          )}
                          <span class="font-bold text-gray-300">
                            {subItem.label}
                          </span>
                        </div>
                        {subItem.description && (
                          <p class="text-xs text-gray-500">
                            {subItem.description}
                          </p>
                        )}
                      </div>
                    )}
                  </li>
                ))}
              </ul>
            </GlassCard>
          ))
        }
      </div>
    </main>
  </div>
</BaseLayout>
