---
interface Props {
  title: string;
  author: string;
  progress: number;
  coverUrl: string;
}

const { title, author, progress, coverUrl } = Astro.props;
---

<div
  class="col-span-1 bg-[#1a1122] p-0 rounded-2xl border border-white/5 overflow-hidden flex flex-col"
>
  <div
    class="h-28 bg-cover bg-center"
    style={`background-image: url('${coverUrl}');`}
  >
  </div>
  <div class="p-5 flex-1 flex flex-col justify-center">
    <div
      class="flex items-center gap-2 text-xs text-primary font-bold uppercase tracking-wider mb-1"
    >
      <span class="material-symbols-outlined text-sm">menu_book</span>
      Reading
    </div>
    <h4 class="text-white font-bold text-lg leading-tight">{title}</h4>
    <p class="text-gray-400 text-xs mt-1">{author}</p>

    <!-- Progress Bar -->
    <div class="w-full bg-white/10 h-1 mt-3 rounded-full overflow-hidden">
      <div class="bg-primary h-full" style={`width: ${progress}%`}></div>
    </div>
  </div>
</div>
