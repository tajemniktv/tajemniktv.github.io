---

<div
  class="col-span-1 md:col-span-2 bg-surface-dark p-6 rounded-2xl border border-white/5 hover:border-primary/50 transition-colors flex flex-col"
>
  <div class="flex items-center justify-between mb-6">
    <h3 class="text-lg font-bold text-white">Elsewhere</h3>
    <div
      class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-white/50"
    >
      <span class="material-symbols-outlined text-sm">public</span>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4 mt-auto">
    {
      links.map((link) => {
        const icon = icons[link.iconName];
        return (
          <a
            class={`flex items-center gap-3 p-3 rounded-xl bg-surface-light ${icon?.bgHover || "hover:bg-white/10"} transition-all group`}
            href={link.href}
          >
            <div
              class={`text-white/70 ${icon?.hoverColor || "group-hover:text-white"}`}
            >
              <svg
                class="w-6 h-6 fill-current"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d={icon?.path || ""} />
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-white font-bold text-sm">{link.title}</span>
              <span class="text-white/40 text-xs">{link.subtitle}</span>
            </div>
          </a>
        );
      })
    }
  </div>
</div>
