---
interface Props {
  title: string;
  excerpt: string;
  readTime: string;
  coverUrl: string;
}

const { title, excerpt, readTime, coverUrl } = Astro.props;
---

<div
  class="col-span-1 md:col-span-2 bg-surface-dark relative overflow-hidden rounded-2xl group cursor-pointer min-h-[240px] flex items-end shadow-lg transition-transform duration-300 hover:-translate-y-1"
>
  <div
    class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105"
    style={`background-image: url('${coverUrl}');`}
  >
  </div>
  <div
    class="absolute inset-0 bg-gradient-to-t from-[#130b1a] via-[#130b1a]/60 to-transparent"
  >
  </div>

  <div class="relative z-10 p-6 w-full">
    <div class="flex items-center gap-2 mb-2">
      <span
        class="bg-white/10 backdrop-blur-md px-2 py-1 rounded-md text-xs font-bold uppercase tracking-wider text-white"
        >Latest Essay</span
      >
      <span class="text-xs text-gray-200 font-medium">{readTime}</span>
    </div>
    <h3
      class="text-2xl font-bold text-white mb-2 leading-tight group-hover:text-primary transition-colors"
    >
      {title}
    </h3>
    <p class="text-gray-200 text-sm line-clamp-2 font-medium">{excerpt}</p>
  </div>
</div>
