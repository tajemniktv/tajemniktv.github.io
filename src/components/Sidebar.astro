---

---

<aside
  class="hidden lg:flex fixed left-8 top-8 bottom-8 w-20 flex-col items-center glass-card rounded-full py-6 z-50 shadow-[0_0_40px_-10px_rgba(127,19,236,0.3)]"
>
  <div class="flex flex-col items-center gap-6 h-full">
    <!-- Logo -->
    <div
      class="h-10 w-10 flex items-center justify-center bg-primary rounded-full text-white shadow-lg shadow-primary/40 mb-2"
    >
      <span class="material-symbols-outlined text-xl">bolt</span>
    </div>

    <!-- Nav -->
    <nav class="flex flex-col gap-4 w-full px-2 flex-1 justify-center">
      <a
        class="p-3 text-white/60 hover:text-white hover:bg-white/10 rounded-full transition-all group relative flex justify-center"
        href="#"
        aria-label="Home"
      >
        <span class="material-symbols-outlined text-xl">home</span>
        <span
          class="absolute left-14 bg-surface-light border border-white/10 text-xs px-2 py-1 rounded-md opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-50 shadow-xl"
          >Home</span
        >
      </a>
      <a
        class="p-3 text-white/60 hover:text-white hover:bg-white/10 rounded-full transition-all group relative flex justify-center"
        href="#writing"
        aria-label="Writing"
      >
        <span class="material-symbols-outlined text-xl">edit_note</span>
        <span
          class="absolute left-14 bg-surface-light border border-white/10 text-xs px-2 py-1 rounded-md opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-50 shadow-xl"
          >Writing</span
        >
      </a>
      <a
        class="p-3 text-white/60 hover:text-white hover:bg-white/10 rounded-full transition-all group relative flex justify-center"
        href="#highlights"
        aria-label="Highlights"
      >
        <span class="material-symbols-outlined text-xl">star</span>
        <span
          class="absolute left-14 bg-surface-light border border-white/10 text-xs px-2 py-1 rounded-md opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-50 shadow-xl"
          >Highlights</span
        >
      </a>
      <a
        class="p-3 text-white/60 hover:text-white hover:bg-white/10 rounded-full transition-all group relative flex justify-center"
        href="#links"
        aria-label="Links"
      >
        <span class="material-symbols-outlined text-xl">link</span>
        <span
          class="absolute left-14 bg-surface-light border border-white/10 text-xs px-2 py-1 rounded-md opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-50 shadow-xl"
          >Links</span
        >
      </a>
    </nav>

    <!-- Bottom Action -->
    <div class="mt-auto">
      <a
        class="p-3 text-primary hover:text-white hover:bg-primary rounded-full transition-all group relative flex justify-center"
        href="#contact"
        aria-label="Contact"
      >
        <span class="material-symbols-outlined text-xl">mail</span>
        <span
          class="absolute left-14 bg-surface-light border border-white/10 text-xs px-2 py-1 rounded-md opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-50 shadow-xl"
          >Contact</span
        >
      </a>
    </div>
  </div>
</aside>
